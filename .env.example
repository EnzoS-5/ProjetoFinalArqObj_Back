# Production Environment Configuration
# Copy to .env and fill in actual values before deployment

# Server Configuration
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database Configuration (use environment-specific database in production)
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/habit_tracker_prod
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# Logging Configuration
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_EXAMPLE_PROJETOFINALAQOBJ=INFO

# Security Configuration
SERVER_SERVLET_CONTEXT_PATH=/

# CORS Origins (production URLs)
# Note: Update SecurityConfig.java with actual production domain
CORS_ALLOWED_ORIGINS=https://projeto-final-arq-obj-front.vercel.app
